#!/usr/bin/env bash
# Block commit unless local CI passes (phase tests + VSIX + coverage).
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

MARKER="${ROOT}/.git/activity-hook-passed"
rm -f "$MARKER"

echo "pre-commit: running local CI (tests + VSIX + coverage)..."
if ! bash "$ROOT/cursor/scripts/run-ci-local.sh"; then
  echo ""
  echo "pre-commit: FAILED — commit blocked. Fix errors above or use: git commit --no-verify" >&2
  exit 1
fi

touch "$MARKER"
echo "pre-commit: OK — post-commit will push if activity.autoPush is enabled"
